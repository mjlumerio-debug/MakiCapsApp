{
  "expo": {
    "name": "MakiCapsApp",
    "slug": "makicapsapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/maki_logo.png",
    "scheme": "makicapsapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/maki_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#D82E3F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mark.makicapsapp",
      "config": {
        "googleMapsApiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_API_KEY}"
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "${EXPO_PUBLIC_GOOGLE_MAPS_API_KEY}"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/maki_logo.png",
        "backgroundColor": "#D82E3F"
      },
      "package": "com.mark.makicapsapp",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/maki_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5623086b-563b-486a-8b1b-b1b1b1b1b1b1"
      }
    }
  }
}
